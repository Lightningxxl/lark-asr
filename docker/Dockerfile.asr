ARG ASR_BASE_IMAGE=nvidia/cuda:13.0.2-cudnn-runtime-ubuntu24.04
FROM ${ASR_BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HOME=/home/app \
    PATH=/opt/lark-asr-venv/bin:/usr/local/bin:/usr/bin:/bin

ARG LARK_CLI_VERSION=1.0.14
ARG CODEX_CLI_VERSION=0.125.0
ARG UBUNTU_APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/ubuntu
ARG NPM_REGISTRY=https://registry.npmjs.org

RUN sed -i \
      -e "s|http://archive.ubuntu.com/ubuntu|${UBUNTU_APT_MIRROR}|g" \
      -e "s|http://security.ubuntu.com/ubuntu|${UBUNTU_APT_MIRROR}|g" \
      /etc/apt/sources.list.d/ubuntu.sources

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      ca-certificates \
      ffmpeg \
      git \
      nodejs \
      npm \
      openssh-client \
      python3 \
      python3-pip \
      python3-venv \
    && rm -rf /var/lib/apt/lists/*

RUN npm config set registry "${NPM_REGISTRY}" \
    && npm install -g \
      @larksuite/cli@${LARK_CLI_VERSION} \
      @openai/codex@${CODEX_CLI_VERSION}

RUN python3 -m venv /opt/lark-asr-venv

COPY requirements-asr.txt /tmp/requirements-asr.txt
RUN python -m pip install --upgrade pip setuptools wheel \
    && python -m pip install --no-cache-dir -r /tmp/requirements-asr.txt

RUN useradd --create-home --uid 1000 app

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src ./src
COPY scripts ./scripts

ENV PYTHONPATH=/app/src

USER app

ENTRYPOINT ["python", "-m", "lark_asr"]
