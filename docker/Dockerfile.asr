ARG ASR_BASE_IMAGE=node:22-bookworm-slim
FROM ${ASR_BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HOME=/home/app \
    PATH=/opt/lark-asr-venv/bin:/usr/local/bin:/usr/bin:/bin

ARG LARK_CLI_VERSION=1.0.14
ARG CODEX_CLI_VERSION=0.125.0
ARG DEBIAN_APT_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/debian
ARG DEBIAN_SECURITY_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/debian-security
ARG NPM_REGISTRY=https://registry.npmjs.org

RUN sed -i \
      -e "s|http://deb.debian.org/debian-security|${DEBIAN_SECURITY_MIRROR}|g" \
      -e "s|http://deb.debian.org/debian|${DEBIAN_APT_MIRROR}|g" \
      /etc/apt/sources.list.d/debian.sources

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      ffmpeg \
      git \
      openssh-client \
      python3 \
      python3-pip \
      python3-venv \
    && rm -rf /var/lib/apt/lists/*

RUN npm config set registry "${NPM_REGISTRY}" \
    && npm install -g \
      @larksuite/cli@${LARK_CLI_VERSION} \
      @openai/codex@${CODEX_CLI_VERSION}

RUN python3 -m venv /opt/lark-asr-venv

COPY requirements-asr.txt /tmp/requirements-asr.txt
RUN python -m pip install --upgrade pip setuptools wheel \
    && python -m pip install --no-cache-dir -r /tmp/requirements-asr.txt

ENV LD_LIBRARY_PATH=/opt/lark-asr-venv/lib/python3.11/site-packages/nvidia/cublas/lib:/opt/lark-asr-venv/lib/python3.11/site-packages/nvidia/cuda_runtime/lib:/opt/lark-asr-venv/lib/python3.11/site-packages/nvidia/cudnn/lib:/opt/lark-asr-venv/lib/python3.11/site-packages/nvidia/cufft/lib:/opt/lark-asr-venv/lib/python3.11/site-packages/nvidia/curand/lib:/opt/lark-asr-venv/lib/python3.11/site-packages/nvidia/cusolver/lib:/opt/lark-asr-venv/lib/python3.11/site-packages/nvidia/cusparse/lib:/opt/lark-asr-venv/lib/python3.11/site-packages/nvidia/nccl/lib:/opt/lark-asr-venv/lib/python3.11/site-packages/nvidia/nvjitlink/lib:/opt/lark-asr-venv/lib/python3.11/site-packages/nvidia/cuda_nvrtc/lib

RUN set -eux; \
    if ! getent group 1000 >/dev/null; then groupadd --gid 1000 app; fi; \
    if ! getent passwd 1000 >/dev/null; then useradd --create-home --uid 1000 --gid 1000 app; fi; \
    mkdir -p /home/app; \
    chown -R 1000:1000 /home/app

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src ./src
COPY scripts ./scripts

ENV PYTHONPATH=/app/src

USER 1000:1000

ENTRYPOINT ["python", "-m", "lark_asr"]
