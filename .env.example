COMPOSE_PROJECT_NAME=lark-asr

# Existing FF1 host paths. These are bind-mounted into containers.
LARK_CLI_CONFIG_DIR=/home/xavierx/.config/lark-cli-token-only
CODEX_HOME=/home/xavierx/.codex
KNOWLEDGEBASE_DIR=/home/xavierx/projects/xfx_knowledge_base

# Mount the directory that contains whisper-large-v3-ct2-float16.
# On FF1 this avoids redownloading the 3GB CT2 model.
MODELS_DIR=/home/xavierx/codex-transcript-20260512/models/AI-ModelScope

WORKER_INTERVAL=20

# Build-time pins.
LARK_ASR_APP_IMAGE=lark-asr/app:local
LARK_ASR_ASR_IMAGE=lark-asr/asr:local
APP_BASE_IMAGE=node:22-bookworm-slim
ASR_BASE_IMAGE=nvidia/cuda:13.0.2-cudnn-runtime-ubuntu24.04
LARK_CLI_VERSION=1.0.14
CODEX_CLI_VERSION=0.125.0

# Build mirrors. Defaults are chosen for FF1's current network.
DEBIAN_APT_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/debian
DEBIAN_SECURITY_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/debian-security
UBUNTU_APT_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/ubuntu
NPM_REGISTRY=https://registry.npmjs.org
